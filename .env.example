# Wazuh REST API
WAZUH_API_URL=https://localhost:55000
WAZUH_API_USER=wazuh
WAZUH_API_PASS=wazuh

# Docker — leave blank to use the default socket (/var/run/docker.sock)
# Set to a TCP address if running Docker remotely, e.g. tcp://192.168.1.10:2375
DOCKER_HOST=

# Name or ID of the wazuh-manager container (leave blank for auto-discovery)
WAZUH_CONTAINER=

# Docker network name used by your Wazuh deployment (run: docker network ls)
# Only needed when running wazuh-web-manager in Docker itself
WAZUH_NETWORK=single-node_default

# Wazuh dashboard port (default 443 for single-node Docker setup)
WAZUH_DASHBOARD_PORT=443

# Session secret — change this to a random string in production
SESSION_SECRET=change-me-to-a-random-string
COOKIE_SECURE=false

# Local storage for snapshots/history
DATA_DIR=./data

# Web server
PORT=1234
